<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TCL | SUNPOWER Products</title>
  <style>
    :root {
      --blue: #001fa7;
      --blue-2: #0a43ff;
      --ink: #2f3033;
      --muted: #6c7280;
      --line: #e7e9ef;
      --panel: #ffffff;
      --page: #f3f3f4;
      --success: #14883e;
      --warning: #767b86;
      --soft-blue: #eef3ff;
      --purple: #762783;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      color: var(--ink);
      background: var(--page);
      font-family: Inter, "Segoe UI", Arial, sans-serif;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .topbar {
      height: 66px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      box-shadow: 0 1px 0 rgba(16, 24, 40, 0.06);
      position: sticky;
      top: 0;
      z-index: 5;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 9px;
      min-width: 230px;
      font-weight: 800;
      letter-spacing: 0.02em;
      color: #111;
    }

    .brand .tcl {
      font-size: 28px;
      line-height: 1;
    }

    .brand .divider {
      height: 28px;
      width: 1px;
      background: #222;
    }

    .brand .sunpower {
      font-size: 22px;
      font-weight: 500;
      letter-spacing: 0.16em;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 28px;
      font-size: 16px;
      height: 100%;
      white-space: nowrap;
    }

    .nav a {
      height: 100%;
      display: flex;
      align-items: center;
      position: relative;
      color: #26282d;
    }

    .nav a.active::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 3px;
      border-radius: 8px 8px 0 0;
      background: var(--blue);
    }

    .actions {
      display: flex;
      align-items: center;
      gap: 18px;
      color: #2c2f36;
      font-size: 15px;
    }

    .icon {
      width: 24px;
      height: 24px;
      display: grid;
      place-items: center;
      position: relative;
      color: #222;
    }

    .badge {
      position: absolute;
      top: -8px;
      right: -10px;
      width: 22px;
      height: 22px;
      border-radius: 999px;
      color: #fff;
      background: var(--blue);
      font-size: 12px;
      line-height: 22px;
      text-align: center;
      font-weight: 700;
    }

    .avatar {
      width: 27px;
      height: 27px;
      border-radius: 50%;
      background: #c7ccd5;
      display: inline-block;
      position: relative;
    }

    .avatar::before {
      content: "";
      position: absolute;
      top: 6px;
      left: 9px;
      width: 9px;
      height: 9px;
      background: #fff;
      border-radius: 50%;
    }

    .avatar::after {
      content: "";
      position: absolute;
      left: 6px;
      bottom: 4px;
      width: 15px;
      height: 9px;
      background: #fff;
      border-radius: 10px 10px 6px 6px;
    }

    .page {
      max-width: 1460px;
      margin: 0 auto;
      padding: 18px 24px 46px;
    }

    .hero {
      min-height: 230px;
      border-radius: 0;
      color: #fff;
      overflow: hidden;
      background:
        radial-gradient(circle at 86% 20%, rgba(255,255,255,0.22), transparent 30%),
        linear-gradient(106deg, var(--purple) 0%, var(--purple) 55%, #2637aa 55%, #0032a0 100%);
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      align-items: stretch;
      position: relative;
    }

    .hero-copy {
      padding: 42px 50px;
      position: relative;
      z-index: 1;
    }

    .eyebrow {
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      opacity: 0.82;
      margin-bottom: 12px;
    }

    h1 {
      font-size: 60px;
      line-height: 0.95;
      letter-spacing: 0.1em;
      font-weight: 300;
      margin: 0 0 18px;
    }

    .hero h2 {
      font-size: 34px;
      line-height: 1.12;
      margin: 0 0 14px;
      max-width: 740px;
    }

    .hero p {
      margin: 0;
      font-size: 20px;
      line-height: 1.35;
      max-width: 720px;
      opacity: 0.95;
    }

    .hero-art {
      position: relative;
      min-height: 230px;
    }

    .floating-card {
      position: absolute;
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.24);
      color: #1f2530;
      overflow: hidden;
    }

    .doc-card {
      width: 255px;
      height: 160px;
      top: 30px;
      left: 54px;
      transform: rotate(-18deg);
      padding: 18px;
    }

    .doc-card strong {
      color: var(--blue);
      font-size: 19px;
      line-height: 1.05;
      display: block;
      margin-bottom: 12px;
    }

    .doc-line {
      height: 8px;
      border-radius: 999px;
      background: #e7ebf5;
      margin: 8px 0;
    }

    .module-card {
      width: 270px;
      height: 155px;
      right: 40px;
      top: 34px;
      transform: rotate(13deg);
      padding: 14px;
    }

    .mini-panel {
      width: 138px;
      height: 88px;
      background: #111827;
      border-radius: 5px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4px;
      padding: 8px;
      margin: 4px auto 10px;
    }

    .mini-panel span {
      border-radius: 2px;
      background: linear-gradient(145deg, #172554, #263d88);
      border: 1px solid #4667c8;
    }

    .kit-card {
      width: 300px;
      height: 126px;
      right: 164px;
      bottom: 20px;
      transform: rotate(-3deg);
      padding: 18px;
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .battery-icon {
      width: 74px;
      height: 86px;
      border-radius: 12px;
      background: #f1f5ff;
      border: 2px solid #d7e1fa;
      display: grid;
      gap: 7px;
      padding: 12px;
    }

    .battery-icon span {
      background: #0c2ba8;
      border-radius: 5px;
    }

    .grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 348px;
      gap: 16px;
      margin-top: 10px;
      align-items: start;
    }

    .card {
      background: var(--panel);
      border-radius: 8px;
      box-shadow: 0 1px 0 rgba(16, 24, 40, 0.03);
      border: 1px solid rgba(231, 233, 239, 0.55);
    }

    .filters {
      padding: 18px;
      margin: 10px 0 16px;
    }

    .filters-row {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 12px;
      align-items: center;
    }

    .search {
      grid-column: span 2;
    }

    .search,
    .select {
      min-height: 46px;
      border: 1px solid #dfe3ea;
      border-radius: 7px;
      background: #fff;
      display: flex;
      align-items: center;
      gap: 10px;
      color: #596171;
      padding: 0 14px;
      font-size: 14px;
    }

    .search input,
    .select select {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: inherit;
      font: inherit;
    }

    .search input::placeholder {
      color: #7a8191;
    }

    .select {
      color: #252a33;
      font-weight: 700;
      white-space: nowrap;
      background: #fbfcff;
    }

    .filters small {
      display: block;
      margin-top: 12px;
      color: var(--muted);
      font-size: 13px;
    }

    .media-frame {
      position: relative;
      overflow: hidden;
    }

    .brand-badge {
      position: absolute;
      top: 14px;
      left: 14px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.95);
      border: 1px solid rgba(223,228,239,0.95);
      color: #222a36;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      box-shadow: 0 8px 20px rgba(17, 24, 39, 0.08);
    }

    .brand-badge.tcl {
      color: #4a505f;
    }

    .section-title {
      display: flex;
      justify-content: space-between;
      align-items: end;
      margin: 0 0 12px;
    }

    .section-title h2 {
      font-size: 34px;
      margin: 0;
      line-height: 1;
    }

    .section-title a {
      color: var(--blue);
      font-weight: 700;
      font-size: 15px;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      align-content: start;
    }

    .product {
      overflow: hidden;
      display: flex;
      flex-direction: column;
      min-height: 590px;
    }

    .product img {
      display: none;
    }

    .product-media-link {
      display: block;
      background: #edf2fb;
      min-height: 202px;
    }

    .product-body {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      flex: 1;
    }

    .product-head {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: start;
    }

    .product h3 {
      margin: 0 0 6px;
      font-size: 21px;
      line-height: 1.15;
      color: #262a31;
    }

    .product-title-link {
      display: inline-block;
    }

    .product-title-link:hover h3 {
      color: var(--blue);
    }

    .product .sub {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.3;
    }

    .detail-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 10px;
      color: var(--blue);
      font-size: 13px;
      font-weight: 800;
    }

    .status {
      border-radius: 999px;
      padding: 7px 10px;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
      color: var(--success);
      background: #e9f7ee;
    }

    .status.out {
      color: var(--warning);
      background: #f1f2f4;
    }

    .specs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .spec {
      background: #f8faff;
      border: 1px solid #edf1fa;
      border-radius: 7px;
      padding: 10px;
      min-height: 66px;
    }

    .spec b {
      display: block;
      font-size: 15px;
      margin-bottom: 4px;
    }

    .spec span {
      color: var(--muted);
      font-size: 12px;
    }

    .qty {
      border-top: 1px solid var(--line);
      padding-top: 14px;
      margin-top: auto;
    }

    .qty-total {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }

    .qty-label {
      display: block;
      margin-bottom: 8px;
      text-align: center;
      font-size: 14px;
      color: #252a33;
      font-weight: 800;
    }

    .stepper {
      height: 44px;
      border: 1px solid #dfe3ea;
      border-radius: 8px;
      display: grid;
      grid-template-columns: 42px 1fr 42px;
      align-items: center;
      text-align: center;
      font-weight: 800;
      color: #252a33;
      overflow: hidden;
      background: #fff;
    }

    .stepper button {
      height: 100%;
      border: 0;
      background: #f7f8fb;
      color: var(--blue);
      font-size: 22px;
      cursor: pointer;
    }

    .cta {
      height: 46px;
      border: 0;
      border-radius: 8px;
      background: var(--blue);
      color: #fff;
      font-size: 15px;
      font-weight: 800;
      margin-top: 12px;
      cursor: pointer;
    }

    .cta.ghost {
      background: #fff;
      color: var(--blue);
      border: 1px solid #d9e2ff;
    }

    .cta.requested {
      background: #e9f7ee;
      color: var(--success);
    }

    .stepper button:disabled,
    .cta:disabled {
      cursor: not-allowed;
      opacity: 0.6;
    }

    .request-feedback {
      margin-top: 10px;
      min-height: 18px;
      font-size: 12px;
      color: var(--muted);
    }

    .summary {
      position: sticky;
      top: 82px;
      padding: 24px;
    }

    .summary h2 {
      margin: 0 0 18px;
      font-size: 33px;
      line-height: 1;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 14px 0;
      border-bottom: 1px solid var(--line);
      font-size: 14px;
      color: var(--muted);
    }

    .summary-row b {
      color: #252a33;
      font-size: 15px;
      text-align: right;
    }

    .summary-list {
      display: grid;
      gap: 10px;
      margin: 16px 0 2px;
    }

    .summary-item {
      border: 1px solid #e6ebf5;
      border-radius: 9px;
      padding: 12px;
      background: #fbfcff;
    }

    .summary-item-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: start;
      margin-bottom: 8px;
    }

    .summary-item-title {
      font-size: 14px;
      font-weight: 800;
      color: #1f2530;
      line-height: 1.3;
    }

    .summary-item-meta {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .summary-remove {
      border: 0;
      background: transparent;
      color: #7a8191;
      font-size: 20px;
      line-height: 1;
      cursor: pointer;
      padding: 0;
    }

    .summary-empty {
      padding: 14px 0 2px;
      color: var(--muted);
      font-size: 13px;
    }

    .summary .cta {
      width: 100%;
      margin-top: 20px;
    }

    .summary p {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
      margin: 12px 0 0;
    }

    .summary-note {
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 8px;
      background: #f8faff;
      color: #40506b;
      font-size: 13px;
      line-height: 1.45;
    }

    .text-link {
      display: inline-flex;
      margin-top: 12px;
      border: 0;
      background: transparent;
      color: var(--blue);
      font-weight: 700;
      cursor: pointer;
      padding: 0;
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: none;
      place-items: center;
      padding: 24px;
      background: rgba(20, 25, 36, 0.52);
    }

    .modal-backdrop.open { display: grid; }

    .request-modal {
      width: min(620px, 100%);
      max-height: calc(100vh - 48px);
      overflow: auto;
      background: #fff;
      border-radius: 8px;
      padding: 28px;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.22);
    }

    .modal-head { display: flex; justify-content: space-between; gap: 20px; align-items: start; }
    .modal-head h2 { margin: 0; font-size: 26px; }
    .modal-close { border: 0; background: transparent; font-size: 26px; cursor: pointer; color: #697181; }
    .modal-copy { color: var(--muted); font-size: 14px; line-height: 1.55; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }
    .form-field { display: grid; gap: 7px; }
    .form-field.full { grid-column: 1 / -1; }
    .form-field label { font-size: 13px; font-weight: 800; color: #303744; }
    .form-field select, .form-field input, .form-field textarea {
      width: 100%; border: 1px solid #d8deea; border-radius: 7px; padding: 11px 12px; font: inherit; background: #fff;
    }
    .form-field textarea { min-height: 92px; resize: vertical; }
    .consent-box { margin-top: 18px; padding: 14px; border: 1px solid #dfe5f2; border-radius: 8px; background: #f8faff; font-size: 13px; line-height: 1.5; }
    .consent-box label { display: flex; gap: 10px; align-items: start; }
    .modal-error { min-height: 18px; margin-top: 10px; color: #d43a3a; font-size: 13px; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 18px; }
    .modal-actions .cta { width: auto; margin: 0; padding-inline: 22px; }
    .success-panel { display: none; text-align: center; padding: 18px 8px 4px; }
    .success-panel.show { display: block; }
    .success-mark { width: 54px; height: 54px; margin: 0 auto 14px; border-radius: 50%; display: grid; place-items: center; background: #e9f7ee; color: var(--success); font-size: 28px; font-weight: 900; }
    .history-record { margin-top: 18px; text-align: left; border: 1px solid #e1e6f0; border-radius: 8px; padding: 14px; background: #fbfcff; }

    @media (max-width: 640px) { .form-grid { grid-template-columns: 1fr; } }

    .tier {
      margin-top: 16px;
      border-radius: 8px;
      padding: 15px;
      background: linear-gradient(135deg, #eef4ff, #ffffff);
      border: 1px solid #e3eaff;
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .tier-mark {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--blue);
      color: #fff;
      display: grid;
      place-items: center;
      font-weight: 900;
    }

    .tier strong {
      display: block;
      margin-bottom: 3px;
    }

    .tier span {
      color: var(--muted);
      font-size: 13px;
    }

    .footer {
      background: #1e1e1f;
      color: #fff;
      text-align: center;
      padding: 34px 20px 28px;
      margin-top: 22px;
    }

    .footer .brand {
      color: #fff;
      justify-content: center;
      margin: 0 auto 24px;
    }

    .footer .divider {
      background: #fff;
    }

    .social {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 12px;
    }

    .social span {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #f60;
      display: inline-block;
    }

    .social span:nth-child(2) {
      background: #0077b5;
    }

    .footer small {
      color: #c7c7c7;
      font-size: 12px;
    }

    svg {
      width: 22px;
      height: 22px;
      stroke: currentColor;
      stroke-width: 1.8;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    @media (max-width: 1180px) {
      .topbar {
        overflow-x: auto;
        gap: 28px;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .summary {
        position: static;
      }

      .products {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 820px) {
      .page {
        padding: 12px;
      }

      .brand {
        min-width: auto;
      }

      .brand .tcl {
        font-size: 22px;
      }

      .brand .sunpower {
        font-size: 16px;
      }

      .nav {
        gap: 18px;
      }

      .actions .email {
        display: none;
      }

      .hero {
        grid-template-columns: 1fr;
      }

      .hero-copy {
        padding: 30px 24px;
      }

      h1 {
        font-size: 44px;
      }

      .hero h2 {
        font-size: 28px;
      }

      .hero p {
        font-size: 17px;
      }

      .hero-art {
        min-height: 190px;
      }

      .doc-card {
        left: 16px;
      }

      .module-card {
        right: 10px;
      }

      .kit-card {
        right: 56px;
      }

      .filters-row,
      .products {
        grid-template-columns: 1fr;
      }

      .product {
        min-height: auto;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="#">
      <span class="tcl">TCL</span>
      <span class="divider"></span>
      <span class="sunpower">SUNPOWER</span>
    </a>
    <nav class="nav" aria-label="Primary navigation">
      <a href="#">Home</a>
      <a href="#">Lead</a>
      <a href="#">Warranty</a>
      <a href="#">Marketing</a>
      <a href="#">Academy</a>
      <a href="#">Live training</a>
      <a href="#">Monitoring</a>
      <a class="active" href="#">Products</a>
    </nav>
    <div class="actions">
      <span class="icon" aria-label="Language">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18"></path></svg>
      </span>
      <span class="icon" aria-label="Messages">
        <svg viewBox="0 0 24 24"><path d="M4 6h16v12H4z"></path><path d="m4 7 8 6 8-6"></path></svg>
        <span class="badge">3</span>
      </span>
      <span class="ava